{
  "name": "clutchq-server",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed": "node scripts/seed.js",
    "seed:demo": "node scripts/seedDemoAccounts.js",
    "seed:games": "node seed/gameSeed.js",
    "sync:external-games": "node scripts/syncExternalGames.js",
    "test": "npm run test:server && npm run test:analytics",
    "test:server": "node --test tests/backendHardening.test.js",
    "test:analytics": "python -m unittest discover ../analytics-worker/tests -p \"test_*.py\"",
    "test:email": "node scripts/testEmail.js",
    "clear": "node scripts/clearDb.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.0",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
